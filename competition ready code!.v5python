{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\n\n\n# wait for rotation sensor to fully initialize\nwait(30, MSEC)\n\n\n# Make random actually random\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    random = brain.battery.voltage(MV) + brain.battery.current(CurrentUnits.AMP) * 100 + brain.timer.system_high_res()\n    urandom.seed(int(random))\n      \n# Set random seed \ninitializeRandomSeed()\n\n\ndef play_vexcode_sound(sound_name):\n    # Helper to make playing sounds from the V5 in VEXcode easier and\n    # keeps the code cleaner by making it clear what is happening.\n    print(\"VEXPlaySound:\" + sound_name)\n    wait(5, MSEC)\n\n# add a small delay to make sure we don't print in the middle of the REPL header\nwait(200, MSEC)\n# clear the console to make sure we don't have the REPL in the console\nprint(\"\\033[2J\")\n\n#endregion VEXcode Generated Robot Configuration\n\n# ------------------------------------------\n# \n# \tProject:\n#\tAuthor:\n#\tCreated:\n#\tConfiguration:\n# \n# ------------------------------------------\n\n# Library imports\nfrom vex import *\n\n# Begin project code\n\n# 1.05 m/s @ 200 RPM (full speed)\n\nleft_motor = Motor(Ports.PORT1, GearSetting.RATIO_18_1, False)\nright_motor = Motor(Ports.PORT2, GearSetting.RATIO_18_1, True)\nmotor_group = MotorGroup(left_motor,right_motor)\nchain_load_motor = Motor(Ports.PORT19, GearSetting.RATIO_18_1, False)\nwheel_load_motor = Motor(Ports.PORT20, GearSetting.RATIO_18_1, True)\ncontroller_1 = Controller(PRIMARY)\nspeed_offset = 1.8\n\ndef pre_autonomous():\n    # actions to do when the program starts\n    brain.screen.clear_screen()\n    brain.screen.print(\"pre auton code\")\n    wait(1, SECONDS)\n\ndef autonomous():\n    brain.screen.clear_screen()\n    brain.screen.print(\"autonomous code\")\n    # place automonous code here\n    \"\"\"\n    left_motor.set_velocity(100,PERCENT)\n    left_motor.spin(FORWARD)\n    wait(0.05,SECONDS)\n    left_motor.set_velocity(0,PERCENT)\n    \"\"\"\n    driv_straight(1, 0.2)\n    wait(0.5,SECONDS)\n    driv_turnL(1,0.5)\n\ndef user_control():\n    brain.screen.clear_screen()\n    # place driver control in this while loop\n    while True:\n        drive_cycle(left_motor, right_motor)\n        loading_cycle(wheel_load_motor, chain_load_motor)\n        #left_motor.spin(FORWARD)\n        #right_motor.spin(FORWARD)\n        motor_group.spin(FORWARD)\n        wheel_load_motor.spin(FORWARD)\n        chain_load_motor.spin(FORWARD)\n        wait(20, MSEC)\n\n# create competition instance\ncomp = Competition(user_control, autonomous)\npre_autonomous()\n\ndef driv_straight(dist_to_move, speed):\n    if speed > 1:\n        speed = 1\n    elif speed < -1:\n        speed = -1\n    left_motor.set_velocity(200*speed, RPM)\n    right_motor.set_velocity(200*speed, RPM)\n    motor_group.spin(FORWARD)\n    wait(dist_to_move/(1.05*speed), SECONDS)\n    left_motor.set_velocity(0, RPM)\n    right_motor.set_velocity(0, RPM)\n        \ndef driv_turnL(dist_to_move, speed):\n    if speed > 1:\n        speed = 1\n    elif speed < -1:\n        speed = -1\n    left_motor.set_velocity(-(200*speed), RPM)\n    right_motor.set_velocity(200*speed, RPM)\n    left_motor.spin(FORWARD)\n    right_motor.spin(FORWARD)\n    wait(dist_to_move/(1.05*speed), SECONDS)\n    left_motor.set_velocity(0, RPM)\n    right_motor.set_velocity(0, RPM)\n\ndef driv_turnR(dist_to_move, speed):\n    if speed > 1:\n        speed = 1\n    elif speed < -1:\n        speed = -1\n    left_motor.set_velocity((200*speed), RPM)\n    right_motor.set_velocity(-(200*speed), RPM)\n    left_motor.spin(FORWARD)\n    right_motor.spin(FORWARD)\n    wait(dist_to_move/(1.05*speed), SECONDS)\n    left_motor.set_velocity(0, RPM)\n    right_motor.set_velocity(0, RPM)\n\ndef activate_load_lift(speed, wait_for):\n    chain_load_motor.set_velocity(200*speed,RPM)\n    chain_load_motor.spin(FORWARD)\n    wait(wait_for, SECONDS)\n    chain_load_motor.set_velocity(0,RPM)\n\ndef activate_load_wheels(speed, wait_for):\n    wheel_load_motor.set_velocity(200*speed,RPM)\n    wheel_load_motor.spin(FORWARD)\n    wait(wait_for, SECONDS)\n    wheel_load_motor.set_velocity(0,RPM)\n\ndef drive_cycle(left_motor, right_motor): # setting motors to the values of the left controller position\n    #if abs(controller_1.axis4.position()) < 10:\n    #    left_motor.set_velocity((controller_1.axis3.position()) / speed_offset, PERCENT)\n    #    right_motor.set_velocity((controller_1.axis3.position()) / speed_offset, PERCENT)\n    #else:\n        left_motor.set_velocity((controller_1.axis3.position() + controller_1.axis4.position()) , PERCENT)\n        right_motor.set_velocity((controller_1.axis3.position() - controller_1.axis4.position()) , PERCENT)\n\ndef loading_cycle(wheel_load_motor, chain_load_motor): # toggling cube motors based on button input\n    if controller_1.buttonUp.pressing(): # loading cubes via toggling motors\n        wheel_load_motor.set_velocity(100,PERCENT)\n        chain_load_motor.set_velocity(80, PERCENT)\n    elif controller_1.buttonDown.pressing(): # de-loading cubes via reversing motors\n        wheel_load_motor.set_velocity(-100,PERCENT)\n        chain_load_motor.set_velocity(-80, PERCENT)\n    else: # stop motors otherwise\n        wheel_load_motor.set_velocity(0,PERCENT)\n        chain_load_motor.set_velocity(0, PERCENT)","textLanguage":"python","robotConfig":[],"slot":0,"platform":"V5","sdkVersion":"20240802.15.00.00","appVersion":"4.64.0","minVersion":"4.60.0","fileFormat":"2.0.0","targetBrainGen":"Second","v5Sounds":[{"name":"game over","url":"static/sounds/mixkit-arcade-retro-game-over-213.wav"}],"v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null},"target":"Physical"}